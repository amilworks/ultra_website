---
import SiteShell from "@/layouts/SiteShell.astro";
import { formatLongDate, getFeaturedNews, getLatestNews } from "@/lib/content";
import ProofStrip from "@/components/ProofStrip.astro";

const featuredStory = await getFeaturedNews();
const latestNews = await getLatestNews(2, featuredStory?.data.slug);
const baseUrl = import.meta.env.BASE_URL;
const canonicalUrl = Astro.site ? new URL(baseUrl, Astro.site).toString() : undefined;
const homeJsonLd = canonicalUrl
  ? {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "BisQue Ultra",
      description:
        "BisQue Ultra is a new scientific work surface built on the BisQue platform for image analysis, model reasoning, and reproducible outputs.",
      url: canonicalUrl,
      about: {
        "@type": "SoftwareApplication",
        name: "BisQue Ultra",
        applicationCategory: "ScientificApplication",
      },
    }
  : undefined;

const toHref = (href: string) =>
  href.startsWith("/") ? `${baseUrl}${href.replace(/^\//, "")}` : href;

if (!featuredStory) {
  throw new Error("Expected at least one news entry for the site homepage.");
}

const homeImage = featuredStory.data.coverImage ?? "/images/news/bisque-ultra-cover.png";
const homeImageAlt =
  featuredStory.data.coverImageAlt ??
  "BisQue Ultra launch artwork with a bright abstract gradient in pink, violet, sand, and electric blue.";
const launchHeroImage = homeImage;
const launchHeroImageAlt = homeImageAlt;
const primaryTileImage = "/images/news/bisque-ultra-launch2.png";
const primaryTileImageAlt =
  "BisQue Ultra showing a prairie dog detection report in a structured interface with a calm sidebar, readable report surface, and integrated prompt composer.";
---

<SiteShell
  title="BisQue Ultra"
  description="BisQue Ultra is a new scientific work surface built on the BisQue platform for image analysis, model reasoning, and reproducible outputs."
  canonicalPath="/"
  image={homeImage}
  imageAlt={homeImageAlt}
  jsonLd={homeJsonLd}
>
  <div class="home-editorial">
    <section class="launch-hero section-block" aria-label="Launch overview">
      <div class="launch-hero-top">
        <div class="section-header launch-hero-copy">
          <p class="eyebrow">Scientific product launch</p>
          <h1 class="launch-headline">A clearer scientific work surface for images, models, and evidence.</h1>
          <p class="launch-subhead">
            Built on the BisQue platform, BisQue Ultra brings uploads, multidimensional viewing, structured
            reasoning, and reproducible artifacts into one readable surface instead of scattering them across tools.
          </p>
        </div>
        <a
          class="launch-hero-art"
          href={toHref(`/news/${featuredStory.data.slug}`)}
          aria-label={`Open ${featuredStory.data.title}`}
        >
          <img
            class="launch-hero-art-image"
            src={toHref(launchHeroImage)}
            alt={launchHeroImageAlt}
            loading="eager"
            decoding="async"
          />
          <span class="launch-hero-badge" aria-hidden="true">
            <span class="launch-hero-badge-subtle">BisQue</span>
            <span class="launch-hero-badge-strong">Ultra</span>
          </span>
        </a>
      </div>
      <div class="hero-actions launch-actions">
        <a class="primary-button" href={toHref(`/news/${featuredStory.data.slug}`)}>Read the flagship article</a>
        <a class="secondary-button" href={toHref("/news")}>Read the launch sequence</a>
      </div>
      <ProofStrip
        items={[
          {
            label: "Platform foundation",
            title: "BisQue stays underneath",
            body: "Storage, metadata, annotations, analysis modules, and up to 5D visualization remain part of the product contract.",
          },
          {
            label: "Model path",
            title: "vLLM + gpt-oss-120b",
            body: "OpenAI-compatible serving, a 128k context window, and fast, auto, and deep reasoning modes.",
          },
          {
            label: "Image boundary",
            title: "BioIO reads real lab files",
            body: "One universal scientific image-loading layer with scenes, channels, dimensions, and physical scale intact.",
          },
          {
            label: "Provenance",
            title: "Runs and artifacts stay visible",
            body: "Uploads, run events, generated outputs, and reproducibility clues remain inspectable after the answer lands.",
          },
        ]}
      />
    </section>

    <section class="launch-spotlight" aria-label="Flagship launch and supporting notes">
      <article class="launch-primary">
        <a
          class="story-tile story-tile-large"
          data-tone="image"
          data-has-image="true"
          href={toHref(`/news/${featuredStory.data.slug}`)}
          aria-label={`Open ${featuredStory.data.title}`}
        >
          <img
            class="story-tile-image"
            src={toHref(primaryTileImage)}
            alt={primaryTileImageAlt}
            style="object-position: 50% 50%"
            loading="eager"
            decoding="async"
          />
        </a>
        <div class="launch-primary-copy">
          <p class="eyebrow">Flagship launch</p>
          <h2 class="story-headline">{featuredStory.data.title}</h2>
          <p class="story-summary">{featuredStory.data.excerpt}</p>
          <p class="story-meta">
            <span>{featuredStory.data.kind}</span>
            <span>{formatLongDate(featuredStory.data.date)}</span>
          </p>
          <div class="hero-actions">
            <a class="primary-button" href={toHref(`/news/${featuredStory.data.slug}`)}>
              {featuredStory.data.kind === "White paper" ? "Read the white paper" : "Read the article"}
            </a>
            <a class="secondary-button" href={toHref("/news")}>Browse product news</a>
          </div>
        </div>
      </article>

      <aside class="launch-reading surface-card">
        <div class="section-header">
          <p class="eyebrow">Read next</p>
          <h2 class="section-title">Two supporting notes that explain the platform and the interface.</h2>
          <p class="section-lead">
            The launch article explains what changed. These two pieces explain what BisQue Ultra stands on
            and why the product feels the way it does.
          </p>
        </div>
        <div class="launch-reading-grid">
          {latestNews.map((entry) => (
            <a class="launch-reading-card" href={toHref(`/news/${entry.data.slug}`)}>
              <p class="launch-reading-meta">
                <span class="post-card-sequence mono-copy">
                  {String(entry.data.sequence ?? 0).padStart(2, "0")}
                </span>
                <span>{entry.data.kind}</span>
              </p>
              <h3 class="story-rail-title">{entry.data.title}</h3>
              <p class="story-summary story-summary-rail">{entry.data.excerpt}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="home-intro section-block">
      <div class="section-header">
        <p class="eyebrow">Why this launch matters</p>
        <h2 class="section-title">A scientific imaging platform, clarified for everyday work.</h2>
        <p class="section-lead">
          BisQue Ultra does not ask scientists to choose between a capable platform and a readable interface.
          It makes the BisQue foundation easier to steer without hiding the evidence that serious work depends on.
        </p>
      </div>
      <figure class="surface-card home-platform-preview">
        <img
          class="home-platform-preview-image home-platform-preview-image-light"
          src={toHref("/images/home/platform-preview-light.png")}
          alt="Light mode BisQue Ultra report view showing a transformer report with structured reading layout."
          loading="lazy"
          decoding="async"
        />
        <img
          class="home-platform-preview-image home-platform-preview-image-dark"
          src={toHref("/images/home/platform-preview-dark.png")}
          alt="Dark mode BisQue Ultra report view showing a transformer report with structured reading layout."
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="home-notes-grid">
        <article class="flat-note">
          <p class="eyebrow">BisQue foundation</p>
          <h3 class="flat-note-title">Store, visualize, organize, and analyze up to 5D image data.</h3>
          <p class="flat-note-copy">
            BisQue is a web-based platform designed for scientific imaging, with flexible metadata,
            graphical and textual annotations, and an open architecture for domain-specific analysis.
          </p>
        </article>
        <article class="flat-note">
          <p class="eyebrow">Workflow continuity</p>
          <h3 class="flat-note-title">From upload to artifact, the path stays inspectable.</h3>
          <p class="flat-note-copy">
            BisQue Ultra keeps resource imports, run events, generated outputs, viewer previews, and
            reproducibility reports close to the same working surface instead of scattering them across
            separate tools.
          </p>
        </article>
        <article class="flat-note">
          <p class="eyebrow">Research breadth</p>
          <h3 class="flat-note-title">Used across biomedical, ecological, and materials workflows.</h3>
          <p class="flat-note-copy">
            BisQue has supported biomedical sciences, neuroscience, wildlife conservation, marine science,
            and materials research. BisQue Ultra is designed to make that breadth easier to navigate.
          </p>
        </article>
      </div>

      <aside class="surface-card home-acknowledgement">
        <div class="home-acknowledgement-copy">
          <p class="eyebrow">About BisQue Ultra</p>
          <h3 class="flat-note-title">Created within the UCSB Vision Research Lab.</h3>
          <p class="flat-note-copy">
            BisQue Ultra was created by Amil Khan, a PhD student in the UCSB Vision Research Lab. The lab
            is led by Professor <a href="https://scholar.google.com/citations?user=wRYM4qgAAAAJ&amp;hl=en" target="_blank" rel="noreferrer">B.S. Manjunath</a> in the Department of Electrical and Computer Engineering,
            with research spanning computer vision, image processing, and machine learning applications.
          </p>
        </div>
        <div class="home-acknowledgement-links">
          <a class="subtle-link" href="https://vision.ece.ucsb.edu" target="_blank" rel="noreferrer">
            Visit UCSB VRL
          </a>
          <a class="subtle-link" href="https://bisque.gitbook.io/docs/" target="_blank" rel="noreferrer">
            Read BisQue docs
          </a>
        </div>
      </aside>
    </section>
  </div>
</SiteShell>
