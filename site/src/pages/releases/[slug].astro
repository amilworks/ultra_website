---
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  return [{ params: { slug: "bisque-ultra" } }];
}) satisfies GetStaticPaths;

const baseUrl = import.meta.env.BASE_URL;
const redirectTarget = `${baseUrl}news/bisque-ultra`;
const canonicalUrl = Astro.site ? new URL(redirectTarget, Astro.site).toString() : redirectTarget;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${redirectTarget}`} />
    <link rel="canonical" href={canonicalUrl} />
    <title>Redirecting to BisQue Ultra</title>
    <script is:inline>{`window.location.replace(${JSON.stringify(redirectTarget)});`}</script>
  </head>
  <body>
    <p>
      Redirecting to <a href={redirectTarget}>the BisQue Ultra launch article</a>.
    </p>
  </body>
</html>
