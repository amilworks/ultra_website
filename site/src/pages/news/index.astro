---
import PostCard from "@/components/PostCard.astro";
import SiteShell from "@/layouts/SiteShell.astro";
import { getAllNews } from "@/lib/content";

const news = await getAllNews();
---

<SiteShell
  title="BisQue Ultra Launch Sequence"
  description="The BisQue Ultra reading sequence: the flagship launch, the BisQue platform foundation, and the frontend design language behind the product."
  canonicalPath="/news"
  image="/images/site-home.svg"
>
  <section class="section-block">
    <div class="section-header">
      <p class="eyebrow">Reading sequence</p>
      <h1 class="section-title">Start with the launch, then read the platform and the interface.</h1>
      <p class="section-lead">
        This site is intentionally short. The flagship article explains what BisQue Ultra is, the platform
        article explains what it stands on, and the design-language article explains why the interface feels
        calm when the work is not.
      </p>
    </div>
    <div class="post-grid">
      {news.map((entry) => (
        <PostCard
          href={`/news/${entry.data.slug}`}
          title={entry.data.title}
          excerpt={entry.data.excerpt}
          date={entry.data.date}
          kind={entry.data.kind}
          sequence={entry.data.sequence}
        />
      ))}
    </div>
  </section>
</SiteShell>
