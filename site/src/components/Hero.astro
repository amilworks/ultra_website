---
type Props = {
  eyebrow: string;
  title: string;
  lead: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
};

const {
  eyebrow,
  title,
  lead,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const toHref = (href: string) =>
  href.startsWith("/") ? `${baseUrl}${href.replace(/^\//, "")}` : href;
---

<section class="hero-card">
  <div class="hero-grid">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-lead">{lead}</p>
      <div class="hero-actions">
        <a class="primary-button" href={toHref(primaryHref)}>{primaryLabel}</a>
        {secondaryHref && secondaryLabel ? (
          <a class="secondary-button" href={toHref(secondaryHref)}>{secondaryLabel}</a>
        ) : null}
      </div>
    </div>
    <div class="section-block">
      <div class="hero-panel">
        <p class="panel-label">Release posture</p>
        <p class="panel-stat">Static by default</p>
        <p class="panel-copy">
          White papers and launch notes stay close to the product shell without inheriting runtime
          complexity or drift.
        </p>
      </div>
      <div class="hero-panel">
        <p class="panel-label">Design language</p>
        <p class="panel-stat">Shared reading system</p>
        <p class="panel-copy">
          Inter sizing, quieter surfaces, restrained mono accents, and the same measured spacing used in
          the app.
        </p>
      </div>
    </div>
  </div>
</section>
